pipeline {

   agent { label 'devops' }
   stages {
      stage('Unregister engines from DCT') {
         agent { label 'devops' }
         steps {
            sh """
                /root/dct-toolkit unregister_engine engine_id=sourcecde 
                /root/dct-toolkit unregister_engine engine_id=cce2 
            """
         }
      }
   }
}