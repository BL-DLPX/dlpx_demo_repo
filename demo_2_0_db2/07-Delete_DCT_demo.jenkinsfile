//
// Pipeline to destroy DCT environment
//
// Demo:  DB2 Demo 2.0
//
// 2026 (c) Delphix - Matteo Ferrari (matteo.ferrari@perforce.com)
//
pipeline {

   agent { label 'devops' }
   stages {
      stage('Delete environments') {
         agent { label 'devops' }
         steps {
            parallel(
                Delete_source: {
                      sh """
                         /root/dct-toolkit delete_environment environment_id='DB2_Source' 
                      """
                },
                Delete_target: {
                      sh """
                         /root/dct-toolkit delete_environment environment_id='DB2_Target' 
                      """
                }
            )
         }
      }
      stage('Unregister engines from DCT') {
         agent { label 'devops' }
         steps {
            sh """
                /root/dct-toolkit unregister_engine engine_id=sourcecde 
                /root/dct-toolkit unregister_engine engine_id=cce 
            """
         }
      }
   }
}