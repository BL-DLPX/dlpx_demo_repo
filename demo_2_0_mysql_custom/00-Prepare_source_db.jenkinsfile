pipeline {

   agent { label 'devops' }
   stages {
      stage('Create source DB tables') {
         agent { label 'devops' }
         steps {
            sh """
            mysql -h 10.160.3.20 -P 3306 -u delphix -pDelphix_123! -e "create database database001;"
            """
         }
      }
   }
}
